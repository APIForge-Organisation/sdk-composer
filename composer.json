{
    "name": "apiforge/apiforgephp",
    "description": "API observability & intelligence for Laravel/PSR-15 — local-first, privacy-first",
    "type": "library",
    "version": "3.0.0",
    "license": "MIT",
    "authors": [
        {"name": "APIForge"}
    ],
    "keywords": [
        "api", "observability", "monitoring", "laravel",
        "metrics", "performance", "middleware", "local-first", "analytics"
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/framework": "^12.55",
        "orchestra/testbench": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "ApiForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApiForge\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ApiForge\\Laravel\\ApiForgeServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/APIForge-Organisation/sdk-composer"
    }
}
